{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lidessen.github.io/skills/chronicle/observation-record.v1.schema.json",
  "title": "Observation Chronicle record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema",
    "kind",
    "occurredAt",
    "recordedAt",
    "subject",
    "observations",
    "method",
    "provenance",
    "quality",
    "observer",
    "recorder",
    "classification"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^obs-[a-z0-9][a-z0-9-]*$" },
    "schema": { "const": "observation-record.v1" },
    "kind": {
      "enum": ["observation", "measurement", "run", "review", "correction"]
    },
    "occurredAt": { "type": "string", "format": "date-time" },
    "recordedAt": { "type": "string", "format": "date-time" },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "value": { "type": ["string", "number", "boolean", "null"] },
          "unit": { "type": "string", "minLength": 1 },
          "uncertainty": { "type": "string", "minLength": 1 }
        }
      }
    },
    "method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "limitations"],
      "properties": {
        "kind": { "enum": ["human-observation", "instrument", "normalization", "calculation"] },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceRole", "sources"],
      "properties": {
        "sourceRole": { "enum": ["primary", "derived"] },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["locator", "role"],
            "properties": {
              "locator": { "type": "string", "minLength": 1 },
              "role": { "enum": ["raw", "supporting", "derived-from"] },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "limitations"],
      "properties": {
        "status": { "enum": ["raw", "reviewed", "uncertain", "retracted"] },
        "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "observer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "enum": ["human", "agent", "system", "organization"] },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "recorder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "enum": ["human", "agent", "tool"] },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "classification": { "enum": ["public", "internal", "restricted"] },
    "correctionOf": { "type": "string", "pattern": "^obs-[a-z0-9][a-z0-9-]*$" }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "correction" } } },
      "then": { "required": ["correctionOf"] }
    }
  ]
}
