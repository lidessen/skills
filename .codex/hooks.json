{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.codex/hooks/intervention-reconciliation.ts\"",
            "timeout": 10,
            "statusMessage": "Checking for a changed task constraint"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.codex/hooks/artifact-consistency.ts\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.codex/hooks/artifact-consistency.ts\""
          }
        ]
      }
    ]
  }
}
