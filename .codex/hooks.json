{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./operations/workbench/rossovia hook intervention codex",
            "timeout": 10,
            "statusMessage": "Checking for a changed task constraint"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "./operations/workbench/rossovia hook artifact codex post-tool-use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./operations/workbench/rossovia hook artifact codex stop"
          }
        ]
      }
    ]
  }
}
